// Prisma Schema for VoiceFlow
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  username          String    @unique
  email             String    @unique
  password          String
  discriminator     String    @default("0001")
  avatar            String?
  banner            String?
  bio               String?
  status            UserStatus @default(OFFLINE)
  customStatus      String?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?
  createdAt         DateTime  @default(now())
  lastSeenAt        DateTime?

  servers           ServerMember[] @relation("UserServers")
  voiceStates       VoiceState[]
  ownedServers      Server[]
  messages          Message[]
  bans              Ban[]       @relation("BannedUser")
  bannedBy          Ban[]       @relation("BannerUser")
  friendships       Friendship[]
  friendshipsTo     Friendship[] @relation("UserTo")
  dms               DMChannel[]
  dmsTo             DMChannel[] @relation("DMChannelTo")
}

enum UserStatus {
  ONLINE
  IDLE
  DND
  OFFLINE
}

model Server {
  id          String   @id @default(uuid())
  name        String
  icon        String?
  ownerId     String
  maxUsers    Int      @default(50)
  createdAt   DateTime @default(now())

  owner       User     @relation(fields: [ownerId], references: [id])
  members     ServerMember[]
  channels    Channel[]
  roles       Role[]
  bans        Ban[]
}

model ServerMember {
  id        String   @id @default(uuid())
  serverId  String
  userId    String
  nickname  String?
  muted     Boolean  @default(false)
  deafened  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user    User   @relation("UserServers", fields: [userId], references: [id], onDelete: Cascade)
  roles   Role[]

  @@unique([serverId, userId])
}

model Role {
  id          String   @id @default(uuid())
  name        String
  color       String   @default("#000000")
  position    Int      @default(0)
  permissions BigInt   @default(0)
  hoist       Boolean  @default(false)
  mentionable Boolean  @default(false)
  serverId    String
  createdAt   DateTime @default(now())

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members ServerMember[]

  @@index([serverId])
}

model Channel {
  id         String      @id @default(uuid())
  name       String
  type       ChannelType @default(VOICE)
  topic      String?
  serverId   String
  parentId   String?
  position   Int         @default(0)
  bitrate    Int         @default(64000)
  maxUsers   Int         @default(0)
  createdAt  DateTime    @default(now())

  server     Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  parent     Channel?    @relation("ChannelHierarchy", fields: [parentId], references: [id])
  children   Channel[]   @relation("ChannelHierarchy")
  voiceStates VoiceState[]
  messages   Message[]

  @@index([serverId])
}

enum ChannelType {
  VOICE
  TEXT
  CATEGORY
}

model VoiceState {
  id            String   @id @default(uuid())
  userId        String
  channelId     String
  serverId      String
  sessionId     String   @unique
  muted         Boolean  @default(false)
  deafened      Boolean  @default(false)
  speaking      Boolean  @default(false)
  videoEnabled  Boolean  @default(false)
  screenSharing Boolean  @default(false)
  joinedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([userId])
  @@index([serverId])
}

model Message {
  id        String   @id @default(uuid())
  content   String
  channelId String
  userId    String
  createdAt DateTime @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([channelId])
  @@index([userId])
}

model Ban {
  id        String   @id @default(uuid())
  serverId  String
  userId    String
  reason    String?
  bannerId  String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  banner User   @relation("BannerUser", fields: [bannerId], references: [id])

  @@unique([serverId, userId])
}

model Friendship {
  id        String             @id @default(uuid())
  userId    String
  friendId  String
  status    FriendshipStatus   @default(PENDING)
  createdAt DateTime           @default(now())

  user   User @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model DMChannel {
  id          String   @id @default(uuid())
  userId      String
  recipientId String
  createdAt   DateTime @default(now())

  user      User    @relation("DMChannelUser", fields: [userId], references: [id], onDelete: Cascade)
  recipient User    @relation("DMChannelRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([userId, recipientId])
}
